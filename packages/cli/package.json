    "date-fns": "^4.4.0",
    "dotenv": "^16.0.0",
    "hono": "^4.12.12",
    "open": "^10.1.0",
    "opentui-spinner": "^0.0.6",
    "pretty-ms": "^9.3.0",
    "react": "^19.2.4",
    "react-router": "^7.14.0",
    "zod": "^4.3.6"
  }
}