{
  "name": "ainightcode",
  "version": "1.0.5",
  "description": "AI-powered coding assistant for your terminal — powered by NightCode",
  "type": "module",
  "author": "NightCode",
  "license": "MIT",
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "cli",
    "terminal",
    "nightcode",
    "ainightcode"
  ],
  "homepage": "https://github.com/Ni3een/NightCode",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ni3een/NightCode.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "ainightcode": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target node --banner '#!/usr/bin/env node'"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.211",
    "@opentui/core": "^0.1.97",
    "@opentui/react": "^0.1.97",
